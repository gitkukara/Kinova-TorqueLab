{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Experiment: run config.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/torque_platform/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Experiment: hold 5s",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/torque_platform/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "--controller",
        "hold",
        "--duration",
        "5"
      ]
    },
    {
      "name": "Plot: latest data",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/torque_platform/plot_results.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Plot: selected data",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/torque_platform/plot_results.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "${input:npzFile}"
      ]
    },
    {
      "name": "Plot: save selected data PNG+PDF",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/torque_platform/plot_results.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "${input:npzFile}",
        "--save",
        "--fmt",
        "png",
        "pdf",
        "--outdir",
        "figures",
        "--no-show"
      ]
    }
  ],
  "inputs": [
    {
      "id": "npzFile",
      "description": "Enter .npz data file path",
      "type": "promptString",
      "default": "torque_platform/data/pid_kinova_.npz"
    }
  ]
}
